# ====================================================================
# NADO TRADING BOT — SIMULATION CONFIG
# Copy this file to .env  (cp .env.example .env)
# ====================================================================

# BOT_MODE options:
# simulation  - existing simulated market/paper behavior
# paper_live  - live/read-only market data with paper trades only
# live        - real orders only if all safety gates pass
BOT_MODE=simulation

# Live execution safety defaults. Keep disabled unless intentionally testing
# the live execution layer with a supported adapter and real credentials.
LIVE_TRADING_ENABLED=false
EXCHANGE_NAME=
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=
LIVE_SYMBOL=
LIVE_ORDER_SIZE_USD=10
MAX_LIVE_ORDER_SIZE_USD=10
MAX_DAILY_LOSS_USD=5
MAX_DAILY_TRADES=5
ALLOW_SHORTS=false
REQUIRE_MANUAL_ARM=true
LIVE_ARM_CONFIRM=

# ─── Market data source ───────────────────────────────────────────────
# SIMULATOR   — synthetic GBM price feed (default, works offline)
# REAL_PUBLIC — live Binance 1-minute candles via public REST API
#               No API key required. Supported symbols: BTC ETH SOL BNB XRP ADA
MARKET_DATA_SOURCE=REAL_PUBLIC

# ─── What to trade ───────────────────────────────────────────────────
SYMBOL=BTC
TRADE_SIDE=LONG
TRADINGVIEW_SYMBOL=BINANCE:BTCUSDT

# ─── Risk controls ───────────────────────────────────────────────────
ORDER_SIZE_USD=100
MAX_CAP_USD=500
TAKE_PROFIT_PCT=0.006
DCA_TRIGGER_PCT=0.015
ALLOW_MULTIPLE_POSITIONS=true
MAX_CONCURRENT_POSITIONS=3
POSITION_SIZING_MODE=RISK_FIRST
TARGET_PROFIT_MIN_USD=1.00
TARGET_PROFIT_MAX_USD=1.50
MAX_RISK_PER_TRADE_USD=1.00
MIN_POSITION_USD=25
MAX_POSITION_USD=500
TARGET_R_MULTIPLE=1.5
HARD_STOP_ENABLED=true

# Signal source: VOLUME_SPIKE or ICT
SIGNAL_SOURCE=ICT
DEBUG_ICT_PIPELINE=true
ICT_TRADE_ON_IFVG_FORMATION=true
ICT_TARGET_SWING_LEFT=3
ICT_TARGET_SWING_RIGHT=3
ICT_TARGET_FALLBACK_LOOKBACK=50
ICT_MIN_CONFIDENCE=75

# ─── Volume Spike Reversal signal ────────────────────────────────────
VOLUME_LOOKBACK=20
VOLUME_SPIKE_MULTIPLIER=2
REVERSAL_DROP_PERCENT=1

# ─── Price simulator (used when MARKET_DATA_SOURCE=SIMULATOR) ────────
# Also sets the fallback starting price for REAL_PUBLIC
START_PRICE=65000
TICK_INTERVAL_MS=2000
PRICE_VOLATILITY=0.80
PRICE_DRIFT=0.0
BASE_VOLUME=800

# ─── REAL_PUBLIC tip ─────────────────────────────────────────────────
# With real data, candles arrive once per minute.
# Set TICK_INTERVAL_MS=60000 to match, or keep 2000 to check TP/DCA more often.
# Signal buffer needs ~20 candles (~20 min) before first trade can fire.

# ─── Session ─────────────────────────────────────────────────────────
STARTING_CAPITAL=10000
