//@version=5
indicator("Nado Bot Fast Parity v8C", overlay=true, max_labels_count=50, max_lines_count=30, max_boxes_count=10)

// Fast Pine mirror of current bot logic.
// Scope: display-only parity for ICT candidate selection, TIGHT_FVG stops,
// risk-first sizing, hard stop, and compact TP/SL visuals.

uiMode = input.string("NORMAL", "UI_MODE", options=["MINIMAL", "NORMAL", "DEBUG"])
showSkips = input.bool(false, "SHOW_SKIPS")
showZone = input.bool(true, "SHOW_SELECTED_ZONE")

ictMinConfidence = input.float(75, "ICT_MIN_CONFIDENCE", minval=0, maxval=100)
exitTargetMode = input.string("HYBRID", "EXIT_TARGET_MODE", options=["STRUCTURE", "SCALP", "HYBRID"])
stopModel = input.string("TIGHT_FVG", "STOP_MODEL", options=["ORIGIN", "TIGHT_FVG"])
targetRMultiple = input.float(1.5, "TARGET_R_MULTIPLE", minval=0.1, step=0.1)
minRR = input.float(1.5, "MIN_RISK_REWARD_RATIO", minval=0.1, step=0.1)
targetProfitMinUsd = input.float(0.50, "TARGET_PROFIT_MIN_USD", minval=0)
targetProfitMaxUsd = input.float(0.75, "TARGET_PROFIT_MAX_USD", minval=0)
maxRiskUsd = input.float(0.50, "MAX_RISK_PER_TRADE_USD", minval=0.01)
minPositionUsd = input.float(25, "MIN_POSITION_USD", minval=0)
maxPositionUsd = input.float(500, "MAX_POSITION_USD", minval=1)
maxTargetDistancePercent = input.float(0, "MAX_TARGET_DISTANCE_PERCENT", minval=0)

validationLookback = input.int(5, "Validation Lookback", minval=1, maxval=20)
dispBodyToRangeMin = input.float(0.6, "Displacement Body/Range Min", minval=0, maxval=1)
dispRangeMultiplier = input.float(1.2, "Displacement Range Multiple", minval=0.1)
swingLookback = input.int(50, "Swing Fallback Lookback", minval=5, maxval=200)

colBuy = color.rgb(46, 204, 113)
colSell = color.rgb(231, 76, 60)
colSkip = color.rgb(140, 140, 140)
colTp = color.rgb(35, 160, 255)
colSl = color.rgb(255, 85, 85)
colEntry = color.rgb(245, 190, 65)

f_bodyClosedBelow(_level) =>
    open < _level and close < _level

f_bodyClosedAbove(_level) =>
    open > _level and close > _level

f_avgRangeBeforeCandle2(_len) =>
    ta.sma(high - low, _len)[2]

f_priorHighBeforeCandle1(_len) =>
    ta.highest(high, _len)[3]

f_priorLowBeforeCandle1(_len) =>
    ta.lowest(low, _len)[3]

f_round2(_v) =>
    math.round(_v * 100.0) / 100.0

f_clamp(_v, _lo, _hi) =>
    math.min(_hi, math.max(_lo, _v))

f_reaction(_active, _zLow, _zHigh, _zMid) =>
    touched = _active and (low <= _zHigh and high >= _zLow)
    touchedMid = _active and (low <= _zMid and high >= _zMid)
    rng = high - low
    body = math.abs(close - open)
    avgR = ta.sma(high - low, 5)[1]
    disp = rng > 0 and avgR > 0 and body / rng >= 0.6 and rng / avgR >= 1.2
    boundaryBull = close > _zHigh
    boundaryBear = close < _zLow
    signal = "NONE"
    tier = "NONE"
    score = 0.0
    if touched or touchedMid
        if disp and boundaryBull
            signal := "BUY"
            tier := "DISPLACEMENT"
            score := 100
        else if disp and boundaryBear
            signal := "SELL"
            tier := "DISPLACEMENT"
            score := 100
        else if boundaryBull
            signal := "BUY"
            tier := "BOUNDARY"
            score := 75
        else if boundaryBear
            signal := "SELL"
            tier := "BOUNDARY"
            score := 75
        else
            tier := "TOUCH"
            score := 20
    [signal, tier, score, disp]

f_stop(_signal, _entry, _zLow, _zHigh, _originStop) =>
    tight = _signal == "BUY" ? _zLow : _zHigh
    tightValid = _signal == "BUY" ? tight < _entry : tight > _entry
    originValid = _signal == "BUY" ? _originStop < _entry : _originStop > _entry
    tightRisk = math.abs(_entry - tight)
    originRisk = math.abs(_entry - _originStop)
    useOrigin = stopModel == "ORIGIN" or not tightValid or (originValid and tightRisk > originRisk)
    selected = useOrigin ? _originStop : tight
    source = useOrigin ? "ORIGIN" : (_signal == "BUY" ? "zoneLow" : "zoneHigh")
    tightened = not useOrigin and originValid and tightRisk < originRisk
    [selected, source, tightened]

f_rr(_target, _entry, _stop) =>
    risk = math.abs(_entry - _stop)
    reward = math.abs(_target - _entry)
    risk > 0 ? reward / risk : na

f_sizing(_signal, _entry, _stop) =>
    riskDistance = math.abs(_entry - _stop)
    riskPct = _entry > 0 ? riskDistance / _entry : na
    rawSize = riskPct > 0 ? maxRiskUsd / riskPct : na
    posUsd = f_clamp(rawSize, minPositionUsd, maxPositionUsd)
    expLoss = posUsd * riskPct
    expProfit = expLoss * targetRMultiple
    tp = _signal == "BUY" ? _entry + riskDistance * targetRMultiple : _entry - riskDistance * targetRMultiple
    rr = riskDistance > 0 ? math.abs(tp - _entry) / riskDistance : na
    accepted = not na(posUsd) and expLoss <= maxRiskUsd + 0.0001 and expProfit >= targetProfitMinUsd and expProfit <= targetProfitMaxUsd + 0.0001 and rr >= minRR
    [accepted, posUsd, expLoss, expProfit, tp, rr]

f_candidate(_active, _isIfvg, _dirBull, _zLow, _zHigh, _originStop, _createdBar, _rangeMult, _longStruct, _shortStruct, _name) =>
    entry = close
    zMid = (_zLow + _zHigh) / 2.0
    [sig, tier, reactScore, dispNow] = f_reaction(_active, _zLow, _zHigh, zMid)
    confidence = _isIfvg ? math.max(reactScore, reactScore) : reactScore
    [sl, stopSource, tightened] = f_stop(sig, entry, _zLow, _zHigh, _originStop)
    [sizingOk, posUsd, expLoss, expProfit, actualTp, actualRR] = f_sizing(sig, entry, sl)
    scalpTp = actualTp
    structTp = sig == "BUY" ? _longStruct : sig == "SELL" ? _shortStruct : na
    structRR = not na(structTp) ? f_rr(structTp, entry, sl) : na
    scalpRR = actualRR
    structDistOk = na(structTp) or maxTargetDistancePercent <= 0 or math.abs(structTp - entry) / entry * 100 <= maxTargetDistancePercent
    structValid = not na(structTp) and not na(structRR) and structRR >= minRR and structDistOk
    selectedForRanking = exitTargetMode == "STRUCTURE" ? structTp : exitTargetMode == "SCALP" ? scalpTp : structValid and math.abs(structTp - entry) <= math.abs(scalpTp - entry) ? structTp : scalpTp
    rankRR = not na(selectedForRanking) ? f_rr(selectedForRanking, entry, sl) : na
    reactionTierScore = tier == "DISPLACEMENT" ? 30.0 : tier == "BOUNDARY" ? 22.0 : 0.0
    dispScore = _rangeMult >= 1.2 ? f_clamp(10.0 + (_rangeMult - 1.2) * (10.0 / 1.8), 0, 20) : dispNow ? 10.0 : 0.0
    rrFitScore = not na(rankRR) and rankRR >= minRR ? (rankRR >= 5 ? 8.0 : 20.0 - ((rankRR - minRR) / math.max(0.01, 5.0 - minRR)) * 12.0) : 0.0
    fitScore = expProfit >= targetProfitMinUsd and expProfit <= targetProfitMaxUsd ? 25.0 : expProfit >= targetProfitMinUsd / 2.0 and expProfit <= targetProfitMaxUsd * 2.0 ? 12.0 : 0.0
    age = math.max(0, bar_index - _createdBar)
    freshScore = age <= 5 ? 15.0 : age <= 20 ? 10.0 : age <= 50 ? 5.0 : 0.0
    movePct = not na(selectedForRanking) ? math.abs(selectedForRanking - entry) / entry * 100 : 0.0
    penalty = exitTargetMode == "SCALP" ? 0.0 : movePct <= 1 ? 0.0 : movePct <= 2 ? 8.0 : movePct <= 5 ? 18.0 : 30.0
    probability = f_clamp(math.round((reactionTierScore + dispScore + rrFitScore + fitScore + freshScore - penalty) * 100.0) / 100.0, 0, 100)
    legacyScore = confidence * 0.45 + (_isIfvg ? 14.0 : 10.0) + fitScore + (sig != "NONE" ? 12.0 : 0.0)
    qualified = _active and (sig == "BUY" or sig == "SELL") and confidence >= ictMinConfidence and (tier == "BOUNDARY" or tier == "DISPLACEMENT") and not na(selectedForRanking) and not na(rankRR) and rankRR >= minRR and sizingOk
    reason = not _active ? "No active zone" : sig == "NONE" ? "Reaction winner NONE" : confidence < ictMinConfidence ? "Below confidence" : tier == "TOUCH" ? "Reaction TOUCH too weak" : na(selectedForRanking) ? "No target" : not sizingOk ? "Sizing rejected" : "Qualified"
    [qualified, sig, probability, legacyScore, confidence, tier, entry, sl, actualTp, actualRR, posUsd, expProfit, expLoss, stopSource, tightened, reason, _name, _zLow, _zHigh]

var float bullLow = na
var float bullHigh = na
var float bullOrigin = na
var int bullCreated = na
var float bullRangeMult = na
var bool bullActive = false

var float bearLow = na
var float bearHigh = na
var float bearOrigin = na
var int bearCreated = na
var float bearRangeMult = na
var bool bearActive = false

var float bullIfvgLow = na
var float bullIfvgHigh = na
var float bullIfvgOrigin = na
var int bullIfvgCreated = na
var float bullIfvgRangeMult = na
var bool bullIfvgActive = false

var float bearIfvgLow = na
var float bearIfvgHigh = na
var float bearIfvgOrigin = na
var int bearIfvgCreated = na
var float bearIfvgRangeMult = na
var bool bearIfvgActive = false

if bullActive and f_bodyClosedBelow(bullLow)
    bearIfvgLow := bullLow
    bearIfvgHigh := bullHigh
    bearIfvgOrigin := high
    bearIfvgCreated := bar_index
    bearIfvgRangeMult := bullRangeMult
    bearIfvgActive := true
    bullActive := false

if bearActive and f_bodyClosedAbove(bearHigh)
    bullIfvgLow := bearLow
    bullIfvgHigh := bearHigh
    bullIfvgOrigin := low
    bullIfvgCreated := bar_index
    bullIfvgRangeMult := bearRangeMult
    bullIfvgActive := true
    bearActive := false

if bullIfvgActive and f_bodyClosedBelow(bullIfvgLow)
    bullIfvgActive := false

if bearIfvgActive and f_bodyClosedAbove(bearIfvgHigh)
    bearIfvgActive := false

enough = bar_index > validationLookback + 4
rawBull = enough and high[2] < low
rawBear = enough and low[2] > high
avgPrior = f_avgRangeBeforeCandle2(validationLookback)
body2 = math.abs(close[1] - open[1])
range2 = high[1] - low[1]
rangeMult = avgPrior > 0 ? range2 / avgPrior : 0.0
bodyOk = range2 > 0 and body2 / range2 >= dispBodyToRangeMin

bullDisp = close[1] > open[1] and bodyOk and rangeMult >= dispRangeMultiplier
bearDisp = close[1] < open[1] and bodyOk and rangeMult >= dispRangeMultiplier
bullMss = close > f_priorHighBeforeCandle1(validationLookback)
bearMss = close < f_priorLowBeforeCandle1(validationLookback)

if rawBull and bullDisp and bullMss
    bullLow := high[2]
    bullHigh := low
    bullOrigin := low[2]
    bullCreated := bar_index
    bullRangeMult := rangeMult
    bullActive := true

if rawBear and bearDisp and bearMss
    bearLow := high
    bearHigh := low[2]
    bearOrigin := high[2]
    bearCreated := bar_index
    bearRangeMult := rangeMult
    bearActive := true

longStruct1 = bearActive and bearLow > close ? bearLow : na
longStruct2 = bearIfvgActive and bearIfvgLow > close ? bearIfvgLow : na
longStruct = na(longStruct1) ? longStruct2 : na(longStruct2) ? longStruct1 : math.min(longStruct1, longStruct2)
longSwing = ta.highest(high, swingLookback)
longStruct := na(longStruct) and longSwing > close ? longSwing : longStruct

shortStruct1 = bullActive and bullHigh < close ? bullHigh : na
shortStruct2 = bullIfvgActive and bullIfvgHigh < close ? bullIfvgHigh : na
shortStruct = na(shortStruct1) ? shortStruct2 : na(shortStruct2) ? shortStruct1 : math.max(shortStruct1, shortStruct2)
shortSwing = ta.lowest(low, swingLookback)
shortStruct := na(shortStruct) and shortSwing < close ? shortSwing : shortStruct

[q1, s1, p1, sc1, c1, t1, e1, sl1, tp1, rr1, ps1, ep1, el1, ss1, st1, r1, n1, zl1, zh1] = f_candidate(bullActive, false, true, bullLow, bullHigh, bullOrigin, bullCreated, bullRangeMult, longStruct, shortStruct, "FVG BULL")
[q2, s2, p2, sc2, c2, t2, e2, sl2, tp2, rr2, ps2, ep2, el2, ss2, st2, r2, n2, zl2, zh2] = f_candidate(bearActive, false, false, bearLow, bearHigh, bearOrigin, bearCreated, bearRangeMult, longStruct, shortStruct, "FVG BEAR")
[q3, s3, p3, sc3, c3, t3, e3, sl3, tp3, rr3, ps3, ep3, el3, ss3, st3, r3, n3, zl3, zh3] = f_candidate(bullIfvgActive, true, true, bullIfvgLow, bullIfvgHigh, bullIfvgOrigin, bullIfvgCreated, bullIfvgRangeMult, longStruct, shortStruct, "IFVG BULL")
[q4, s4, p4, sc4, c4, t4, e4, sl4, tp4, rr4, ps4, ep4, el4, ss4, st4, r4, n4, zl4, zh4] = f_candidate(bearIfvgActive, true, false, bearIfvgLow, bearIfvgHigh, bearIfvgOrigin, bearIfvgCreated, bearIfvgRangeMult, longStruct, shortStruct, "IFVG BEAR")

sel = 0
selProb = -1.0
selDisp = -1.0
selRrFit = -1.0
selTierRank = -1.0
selScore = -1.0

tr1 = t1 == "DISPLACEMENT" ? 2.0 : t1 == "BOUNDARY" ? 1.0 : 0.0
if q1 and (p1 > selProb or (p1 == selProb and tr1 > selTierRank) or (p1 == selProb and tr1 == selTierRank and sc1 > selScore))
    sel := 1
    selProb := p1
    selTierRank := tr1
    selScore := sc1

tr2 = t2 == "DISPLACEMENT" ? 2.0 : t2 == "BOUNDARY" ? 1.0 : 0.0
if q2 and (p2 > selProb or (p2 == selProb and tr2 > selTierRank) or (p2 == selProb and tr2 == selTierRank and sc2 > selScore))
    sel := 2
    selProb := p2
    selTierRank := tr2
    selScore := sc2

tr3 = t3 == "DISPLACEMENT" ? 2.0 : t3 == "BOUNDARY" ? 1.0 : 0.0
if q3 and (p3 > selProb or (p3 == selProb and tr3 > selTierRank) or (p3 == selProb and tr3 == selTierRank and sc3 > selScore))
    sel := 3
    selProb := p3
    selTierRank := tr3
    selScore := sc3

tr4 = t4 == "DISPLACEMENT" ? 2.0 : t4 == "BOUNDARY" ? 1.0 : 0.0
if q4 and (p4 > selProb or (p4 == selProb and tr4 > selTierRank) or (p4 == selProb and tr4 == selTierRank and sc4 > selScore))
    sel := 4
    selProb := p4
    selTierRank := tr4
    selScore := sc4

sig = sel == 1 ? s1 : sel == 2 ? s2 : sel == 3 ? s3 : sel == 4 ? s4 : "NONE"
prob = sel == 1 ? p1 : sel == 2 ? p2 : sel == 3 ? p3 : sel == 4 ? p4 : na
conf = sel == 1 ? c1 : sel == 2 ? c2 : sel == 3 ? c3 : sel == 4 ? c4 : na
tier = sel == 1 ? t1 : sel == 2 ? t2 : sel == 3 ? t3 : sel == 4 ? t4 : "--"
entry = sel == 1 ? e1 : sel == 2 ? e2 : sel == 3 ? e3 : sel == 4 ? e4 : na
sl = sel == 1 ? sl1 : sel == 2 ? sl2 : sel == 3 ? sl3 : sel == 4 ? sl4 : na
tp = sel == 1 ? tp1 : sel == 2 ? tp2 : sel == 3 ? tp3 : sel == 4 ? tp4 : na
rr = sel == 1 ? rr1 : sel == 2 ? rr2 : sel == 3 ? rr3 : sel == 4 ? rr4 : na
posUsd = sel == 1 ? ps1 : sel == 2 ? ps2 : sel == 3 ? ps3 : sel == 4 ? ps4 : na
expP = sel == 1 ? ep1 : sel == 2 ? ep2 : sel == 3 ? ep3 : sel == 4 ? ep4 : na
expL = sel == 1 ? el1 : sel == 2 ? el2 : sel == 3 ? el3 : sel == 4 ? el4 : na
stopSrc = sel == 1 ? ss1 : sel == 2 ? ss2 : sel == 3 ? ss3 : sel == 4 ? ss4 : "--"
tightened = sel == 1 ? st1 : sel == 2 ? st2 : sel == 3 ? st3 : sel == 4 ? st4 : false
selName = sel == 1 ? n1 : sel == 2 ? n2 : sel == 3 ? n3 : sel == 4 ? n4 : "--"
selZLow = sel == 1 ? zl1 : sel == 2 ? zl2 : sel == 3 ? zl3 : sel == 4 ? zl4 : na
selZHigh = sel == 1 ? zh1 : sel == 2 ? zh2 : sel == 3 ? zh3 : sel == 4 ? zh4 : na

botEntry = sel > 0
skipReason = r1 != "Qualified" ? r1 : r2 != "Qualified" ? r2 : r3 != "Qualified" ? r3 : r4 != "Qualified" ? r4 : "No candidate qualified"

var line entryLine = na
var line tpLine = na
var line slLine = na
var label entryLabel = na
var label skipLabel = na
var box zoneBox = na
var table dash = table.new(position.top_right, 2, 10, border_width=1)

if barstate.islast
    if not na(entryLine)
        line.delete(entryLine)
    if not na(tpLine)
        line.delete(tpLine)
    if not na(slLine)
        line.delete(slLine)
    if not na(entryLabel)
        label.delete(entryLabel)
    if not na(skipLabel)
        label.delete(skipLabel)
    if not na(zoneBox)
        box.delete(zoneBox)

    if botEntry
        sideColor = sig == "BUY" ? colBuy : colSell
        entryLine := line.new(bar_index - 1, entry, bar_index + 20, entry, color=colEntry, width=1)
        tpLine := line.new(bar_index - 1, tp, bar_index + 20, tp, color=colTp, width=2)
        slLine := line.new(bar_index - 1, sl, bar_index + 20, sl, color=colSl, width=2)
        if showZone
            zoneBox := box.new(bar_index - 5, selZHigh, bar_index + 5, selZLow, bgcolor=color.new(sideColor, 88), border_color=color.new(sideColor, 20))
        txt = sig + "\n" + str.tostring(f_round2(prob)) + "%\nRR " + str.tostring(f_round2(rr)) + "\n+$" + str.tostring(f_round2(expP)) + " / -$" + str.tostring(f_round2(expL))
        if uiMode == "DEBUG"
            txt += "\n" + selName + "\n" + tier + "\nStop " + stopSrc + "\nTight " + str.tostring(tightened) + "\nSize $" + str.tostring(f_round2(posUsd))
        entryLabel := label.new(bar_index, sig == "BUY" ? low : high, txt, style=sig == "BUY" ? label.style_label_up : label.style_label_down, textcolor=color.white, color=sideColor, size=size.small)
    else if showSkips
        skipLabel := label.new(bar_index, high, "ENTRY SKIP\n" + skipReason, style=label.style_label_down, textcolor=color.white, color=colSkip, size=size.tiny)

    table.clear(dash, 0, 0, 1, 9)
    table.cell(dash, 0, 0, "Nado Fast", text_color=color.white, bgcolor=color.rgb(45,45,55))
    table.cell(dash, 1, 0, syminfo.ticker, text_color=color.white, bgcolor=color.rgb(45,45,55))
    table.cell(dash, 0, 1, "Signal")
    table.cell(dash, 1, 1, sig)
    table.cell(dash, 0, 2, "Probability")
    table.cell(dash, 1, 2, botEntry ? str.tostring(f_round2(prob)) + "%" : "--")
    table.cell(dash, 0, 3, "Reaction")
    table.cell(dash, 1, 3, tier)
    table.cell(dash, 0, 4, "Entry")
    table.cell(dash, 1, 4, botEntry ? str.tostring(entry, format.mintick) : "--")
    table.cell(dash, 0, 5, "TP")
    table.cell(dash, 1, 5, botEntry ? str.tostring(tp, format.mintick) : "--")
    table.cell(dash, 0, 6, "SL")
    table.cell(dash, 1, 6, botEntry ? str.tostring(sl, format.mintick) : "--")
    table.cell(dash, 0, 7, "Expected P/L")
    table.cell(dash, 1, 7, botEntry ? "+$" + str.tostring(f_round2(expP)) + " / -$" + str.tostring(f_round2(expL)) : "--")
    table.cell(dash, 0, 8, "RR / Size")
    table.cell(dash, 1, 8, botEntry ? str.tostring(f_round2(rr)) + " / $" + str.tostring(f_round2(posUsd)) : "--")
    table.cell(dash, 0, 9, "Stop Model")
    table.cell(dash, 1, 9, stopModel)

plotshape(botEntry and sig == "BUY", title="BOT BUY", style=shape.triangleup, location=location.belowbar, color=colBuy, size=size.small, text="BUY")
plotshape(botEntry and sig == "SELL", title="BOT SELL", style=shape.triangledown, location=location.abovebar, color=colSell, size=size.small, text="SELL")
