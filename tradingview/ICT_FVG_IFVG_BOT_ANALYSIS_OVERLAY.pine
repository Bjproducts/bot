//@version=6
indicator("Nado ICT FVG/IFVG Bot Analysis Overlay", overlay = true, max_boxes_count = 160, max_labels_count = 120, max_lines_count = 160)

// This indicator mirrors the bot's current research rules as closely as Pine allows.
// It is visual-only: no strategy orders, broker execution, alerts, or wallet logic.

liquidityLookback = input.int(5, "Liquidity sweep lookback", minval = 1)
mssLookback = input.int(5, "Market structure lookback", minval = 1)
bodyToRangeMin = input.float(0.60, "Displacement body/range minimum", minval = 0, maxval = 1, step = 0.05)
rangeMultiplierMin = input.float(1.20, "Displacement range multiple minimum", minval = 0, step = 0.05)

usePremiumDiscount = input.bool(false, "Evaluate premium/discount")
pdLookback = input.int(20, "Premium/discount lookback", minval = 1)
requireCorrectPd = input.bool(false, "Require correct premium/discount")

useSessionFilter = input.bool(false, "Evaluate UTC session filter")
allowedUtcSession = input.session("0000-2359", "Allowed UTC session")

ictMinConfidence = input.float(75, "ICT minimum confidence", minval = 0, maxval = 100)
tradeOnIfvgFormation = input.bool(true, "Trade fresh IFVG formation")
positionSizingMode = input.string("RISK_FIRST", "POSITION_SIZING_MODE", options = ["RISK_FIRST", "PROFIT_FIRST"])
takeProfitPct = input.float(0.006, "Take profit percent", minval = 0, step = 0.001)
minExpectedProfitUsd = input.float(0.50, "Minimum expected TP profit USD", minval = 0)
preferredMinProfitUsd = input.float(1.00, "Preferred TP profit min USD", minval = 0)
preferredMaxProfitUsd = input.float(1.50, "Preferred TP profit max USD", minval = 0)
targetProfitMinUsd = input.float(1.00, "TARGET_PROFIT_MIN_USD", minval = 0)
targetProfitMaxUsd = input.float(1.50, "TARGET_PROFIT_MAX_USD", minval = 0)
maxRiskPerTradeUsd = input.float(1.00, "Max risk per trade USD", minval = 0)
minPositionUsd = input.float(25, "Minimum position USD", minval = 0)
maxPositionUsd = input.float(500, "Maximum position USD", minval = 0)
minRiskRewardRatio = input.float(1.50, "Minimum risk/reward", minval = 0, step = 0.05)
targetRMultiple = input.float(1.50, "TARGET_R_MULTIPLE", minval = 0.1, step = 0.05)
hardStopEnabled = input.bool(true, "HARD_STOP_ENABLED")
exitTargetMode = input.string("HYBRID", "EXIT_TARGET_MODE", options = ["STRUCTURE", "SCALP", "HYBRID"])

targetSwingLeft = input.int(3, "Target swing left bars", minval = 1)
targetSwingRight = input.int(3, "Target swing right bars", minval = 1)
targetFallbackLookback = input.int(50, "Target fallback high/low lookback", minval = 1)
maxTrackedZones = input.int(80, "Max tracked zones", minval = 20, maxval = 150)
maxEvaluatedZones = input.int(60, "Max evaluated zones per bar", minval = 10, maxval = 150)
activePreviewBars = input.int(3, "Active zone preview bars", minval = 0)
minVisibleZoneBars = input.int(6, "Minimum visible zone bars", minval = 1)
stopZonesAtReaction = input.bool(true, "Stop zones at first reaction")
uiMode = input.string("NORMAL", "UI_MODE", options = ["MINIMAL", "NORMAL", "DEBUG"])
showRawZones = input.bool(true, "SHOW_RAW_ZONES")
showRejectedZones = input.bool(false, "SHOW_REJECTED_ZONES")
showSkips = input.bool(false, "SHOW_SKIPS")
showSelected = input.bool(false, "SHOW_SELECTED")
showScoreBreakdown = input.bool(false, "SHOW_SCORE_BREAKDOWN")
showEntryHighlight = input.bool(true, "SHOW_ENTRY_HIGHLIGHT")
showRejectedRawFvgs = input.bool(false, "Show rejected raw FVG markers")
zoneTextMode = input.string("Off", "Zone text", options = ["Off", "Compact", "Full"])
showLabels = input.bool(true, "Show labels")
showTradeManagement = input.bool(true, "Show targets and BE stop")
keepHistoricalTradeLines = input.bool(false, "Keep historical trade lines")
showTable = input.bool(true, "Show latest analysis table")

bool uiMinimal = uiMode == "MINIMAL"
bool uiDebug = uiMode == "DEBUG"
bool uiVerbose = uiMode != "MINIMAL"

var box[] zoneBoxes = array.new_box()
var line[] midpointLines = array.new_line()
var float[] zoneHighs = array.new_float()
var float[] zoneLows = array.new_float()
var float[] zoneMidpoints = array.new_float()
var string[] zoneDirections = array.new_string()
var string[] zoneTypes = array.new_string()
var string[] zoneIds = array.new_string()
var float[] zoneRangeMultiples = array.new_float()
var int[] zoneCreatedBars = array.new_int()
var bool[] zoneInvalidated = array.new_bool()
var bool[] zoneFilled = array.new_bool()
var bool[] zoneFlipped = array.new_bool()
var bool[] zoneReacted = array.new_bool()

var string latestSignal = "NONE"
var string latestZoneType = "--"
var string latestZoneId = "--"
var float latestConfidence = na
var float latestScore = na
var string latestReason = "Waiting for setup"
var float latestZoneHigh = na
var float latestZoneLow = na
var bool latestSizingAccepted = false
var string latestSizingReason = "--"
var float latestPositionSizeUsd = na
var float latestExpectedProfitUsd = na
var float latestExpectedLossUsd = na
var float latestRiskRewardRatio = na
var float latestRiskUtilizationPercent = na
var bool latestRiskUtilizationWarning = false
var float latestHardStopPrice = na
var float latestExpectedMovePercent = na
var float latestRewardDistance = na
var float latestRiskDistance = na
var float latestTargetReachProbability = na
var string latestReactionTier = "--"
var string latestReactionWinner = "--"
var float latestReactionScore = na
var float latestSelectedTarget = na
var string latestTargetMode = "--"
var string latestTargetSource = "--"
var string latestEntryTime = "--"
var int latestEntryBarIndex = na
var float latestEntryPrice = na
var string latestSkipReason = "--"
var float latestDisplacementScore = na
var float latestReactionTierScore = na
var float latestRrFitScore = na
var float latestScalpTargetFitScore = na
var float latestTargetDistancePenalty = na
var float latestZoneFreshnessScore = na
var string latestRankingText = "--"
var string latestSelectionReason = "--"

var bool activeTrade = false
var string activeTradeDirection = "NONE"
var float activeEntry = na
var float activeTarget = na
var float activeInitialStop = na
var string activeTargetSource = "--"
var int activeEntryBarIndex = na
var string activeEntryTime = "--"
var int activeTargetZoneIndex = na
var bool activeStopAtBe = false
var line activeEntryLine = na
var line activeTargetLine = na
var line activeStopLine = na
var label activeTradeLabel = na
var line activeEntryMarkerLine = na

float c1High = high[2]
float c1Low = low[2]
float c2High = high[1]
float c2Low = low[1]
float c2Open = open[1]
float c2Close = close[1]
float c3High = high
float c3Low = low

bool rawBullishFvg = bar_index >= 2 and c1High < c3Low
bool rawBearishFvg = bar_index >= 2 and c1Low > c3High

float priorSweepHigh = ta.highest(high[3], liquidityLookback)
float priorSweepLow = ta.lowest(low[3], liquidityLookback)
float priorMssHigh = ta.highest(high[3], mssLookback)
float priorMssLow = ta.lowest(low[3], mssLookback)
float avgPriorRange = ta.sma(high - low, liquidityLookback)[2]

float displacementRange = c2High - c2Low
float displacementBody = math.abs(c2Close - c2Open)
float bodyToRange = displacementRange > 0 ? displacementBody / displacementRange : 0
float rangeMultiple = avgPriorRange > 0 ? displacementRange / avgPriorRange : 0
float currentAvgPriorRange = ta.sma(high - low, liquidityLookback)[1]
float currentRange = high - low
float currentBody = math.abs(close - open)
float currentBodyToRange = currentRange > 0 ? currentBody / currentRange : 0
float currentRangeMultiple = currentAvgPriorRange > 0 ? currentRange / currentAvgPriorRange : 0
bool currentDisplacement = currentBodyToRange >= bodyToRangeMin and currentRangeMultiple >= rangeMultiplierMin

bool displacementBullish = c2Close > c2Open and bodyToRange >= bodyToRangeMin and rangeMultiple >= rangeMultiplierMin
bool displacementBearish = c2Close < c2Open and bodyToRange >= bodyToRangeMin and rangeMultiple >= rangeMultiplierMin

bool bullLiquiditySweep = low[2] < priorSweepLow
bool bearLiquiditySweep = high[2] > priorSweepHigh
bool bullMss = close > priorMssHigh
bool bearMss = close < priorMssLow

float pdHigh = ta.highest(high[3], pdLookback)
float pdLow = ta.lowest(low[3], pdLookback)
float equilibrium = (pdHigh + pdLow) / 2

bool sessionOk = not useSessionFilter or not na(time(timeframe.period, allowedUtcSession, "UTC"))

float confirmedSwingHigh = ta.pivothigh(high, targetSwingLeft, targetSwingRight)
float confirmedSwingLow = ta.pivotlow(low, targetSwingLeft, targetSwingRight)
float fallbackHigh = ta.highest(high, targetFallbackLookback)
float fallbackLow = ta.lowest(low, targetFallbackLookback)
var float latestSwingHigh = na
var float latestSwingLow = na

if not na(confirmedSwingHigh)
    latestSwingHigh := confirmedSwingHigh

if not na(confirmedSwingLow)
    latestSwingLow := confirmedSwingLow

premiumDiscountOk(string direction, float midpoint) =>
    if not usePremiumDiscount
        true
    else
        bool isPremium = midpoint > equilibrium
        bool isDiscount = midpoint < equilibrium
        not requireCorrectPd or (direction == "BEARISH" and isPremium) or (direction == "BULLISH" and isDiscount)

rejectionReason(string direction, bool sweepOk, bool displacementOk, bool mssOk, bool pdOk, bool sessOk) =>
    not sweepOk ? (direction == "BEARISH" ? "No buy-side sweep" : "No sell-side sweep") :
     not displacementOk ? "No displacement" :
     not mssOk ? "No MSS" :
     not pdOk ? "Premium/discount failed" :
     not sessOk ? "Session filter failed" :
     ""

zoneBoxText(string zoneType, string direction, float zoneLow, float zoneHigh, float midpoint, string reasonText) =>
    if zoneTextMode == "Off"
        ""
    else if zoneTextMode == "Compact"
        zoneType + " " + (direction == "BULLISH" ? "BULL" : "BEAR") + "\nM " + str.tostring(midpoint, format.mintick)
    else
        zoneType + " " + direction + "\nH: " + str.tostring(zoneHigh, format.mintick) + "\nL: " + str.tostring(zoneLow, format.mintick) + "\nM: " + str.tostring(midpoint, format.mintick) + "\n" + reasonText

findOpposingTarget(string signal, float entryPrice) =>
    float selectedTarget = na
    int selectedIndex = na
    int targetZoneCount = array.size(zoneHighs)
    if targetZoneCount > 0
        int firstTargetIndex = math.max(0, targetZoneCount - maxEvaluatedZones)
        for targetIndex = firstTargetIndex to targetZoneCount - 1
            bool targetInvalidated = array.get(zoneInvalidated, targetIndex)
            string targetDirection = array.get(zoneDirections, targetIndex)
            float targetHigh = array.get(zoneHighs, targetIndex)
            float targetLow = array.get(zoneLows, targetIndex)
            bool buyTarget = signal == "BUY" and targetDirection == "BEARISH" and targetLow > entryPrice
            bool sellTarget = signal == "SELL" and targetDirection == "BULLISH" and targetHigh < entryPrice
            if not targetInvalidated and buyTarget
                if na(selectedTarget) or targetLow < selectedTarget
                    selectedTarget := targetLow
                    selectedIndex := targetIndex
            if not targetInvalidated and sellTarget
                if na(selectedTarget) or targetHigh > selectedTarget
                    selectedTarget := targetHigh
                    selectedIndex := targetIndex
    [selectedTarget, selectedIndex]

fallbackSwingTarget(string signal, float entryPrice) =>
    float fallbackTarget = na
    if signal == "BUY"
        fallbackTarget := not na(latestSwingHigh) and latestSwingHigh > entryPrice ? latestSwingHigh : fallbackHigh
    else if signal == "SELL"
        fallbackTarget := not na(latestSwingLow) and latestSwingLow < entryPrice ? latestSwingLow : fallbackLow
    fallbackTarget

targetZoneDisrespected(string signal, int targetIndex) =>
    bool disrespected = false
    if not na(targetIndex) and targetIndex >= 0 and targetIndex < array.size(zoneHighs)
        float targetHigh = array.get(zoneHighs, targetIndex)
        float targetLow = array.get(zoneLows, targetIndex)
        disrespected := signal == "BUY" ? close > targetHigh : close < targetLow
    disrespected

confidenceSizeMultiplier(float confidence) =>
    confidence >= 95 ? 1.15 : confidence >= 85 ? 1.00 : confidence < 80 ? 0.75 : 0.90

scoreSizeMultiplier(float score) =>
    score >= 90 ? 1.10 : score >= 80 ? 1.00 : score < 70 ? 0.85 : 0.95

roundMoney(float value) =>
    math.round(value * 10000) / 10000

roundScore(float value) =>
    math.round(value * 100) / 100

clampScore(float value) =>
    math.min(100, math.max(0, value))

shortZoneId(string zoneId) =>
    str.length(zoneId) > 18 ? str.substring(zoneId, 0, 18) : zoneId

reactionTierScoreOf(string tier) =>
    tier == "DISPLACEMENT" ? 30 : tier == "BOUNDARY" ? 22 : tier == "MIDPOINT" ? 8 : 0

reactionScoreOf(string tier) =>
    tier == "DISPLACEMENT" ? 100 : tier == "BOUNDARY" ? 75 : tier == "MIDPOINT" ? 45 : tier == "TOUCH" ? 20 : 0

displacementScoreOf(float zoneRangeMultiple, string tier) =>
    zoneRangeMultiple <= 0 ? (tier == "DISPLACEMENT" ? 10 : 0) : zoneRangeMultiple < 1.2 ? 0 : math.round(math.min(20, math.max(0, 10 + (zoneRangeMultiple - 1.2) * (10 / 1.8))))

rrFitScoreOf(float rr) =>
    na(rr) or rr < minRiskRewardRatio ? 0 : rr >= 5 ? 8 : math.round(20 - ((rr - minRiskRewardRatio) / math.max(0.01, 5 - minRiskRewardRatio)) * 12)

scalpTargetFitScoreOf(float expectedProfitUsd) =>
    na(expectedProfitUsd) or expectedProfitUsd <= 0 ? 0 : expectedProfitUsd >= preferredMinProfitUsd and expectedProfitUsd <= preferredMaxProfitUsd ? 25 : expectedProfitUsd >= preferredMinProfitUsd / 2 and expectedProfitUsd <= preferredMaxProfitUsd * 2 ? 12 : 0

zoneFreshnessScoreOf(int createdBar) =>
    int age = math.max(0, bar_index - createdBar)
    age <= 5 ? 15 : age <= 20 ? 10 : age <= 50 ? 5 : 0

targetDistancePenaltyOf(float expectedMovePercent, string mode) =>
    mode == "SCALP" ? 0 : na(expectedMovePercent) or expectedMovePercent <= 0 ? 0 : expectedMovePercent <= 1 ? 0 : expectedMovePercent <= 2 ? 8 : expectedMovePercent <= 5 ? 18 : 30

reactionTierOf(string zoneDirection, bool touchedZone, bool touchedMid, bool currentDisplacement, float zoneHigh, float zoneLow, float zoneMid) =>
    bool bullishBoundary = close > zoneHigh
    bool bearishBoundary = close < zoneLow
    bool bullishFailure = zoneDirection == "BULLISH" and close < zoneMid
    bool bearishFailure = zoneDirection == "BEARISH" and close > zoneMid
    not touchedZone and not touchedMid ? "NONE" : currentDisplacement and (bullishBoundary or bearishBoundary) ? "DISPLACEMENT" : bullishBoundary or bearishBoundary ? "BOUNDARY" : touchedMid or bullishFailure or bearishFailure ? "MIDPOINT" : "TOUCH"

reactionWinnerOf(string zoneDirection, string tier, float zoneHigh, float zoneLow, float zoneMid) =>
    if tier == "DISPLACEMENT" or tier == "BOUNDARY"
        close > zoneHigh ? "BUY" : close < zoneLow ? "SELL" : "NONE"
    else if tier == "MIDPOINT"
        zoneDirection == "BULLISH" and close < zoneMid ? "SELL" : zoneDirection == "BEARISH" and close > zoneMid ? "BUY" : close > zoneMid ? "BUY" : close < zoneMid ? "SELL" : "NONE"
    else
        "NONE"

targetLineColor(string mode) =>
    mode == "STRUCTURE" ? color.fuchsia : mode == "SCALP" ? color.orange : color.lime

skipReasonFor(bool targetValid, bool stopValid, bool sizingAccepted, string sizingReason, float probability, float rr) =>
    not targetValid ? "target too far" :
     not stopValid ? "Invalid target or stop" :
     not na(rr) and rr < minRiskRewardRatio ? "RR too low" :
     not na(probability) and probability < 55 ? "probability too low" :
     not sizingAccepted ? (str.length(sizingReason) > 0 ? sizingReason : "sizing rejected") :
     "--"

calculateSizing(float confidence, float selectionScore, float entryPrice, float targetPrice, float stopPrice) =>
    float rewardDistance = math.abs(targetPrice - entryPrice)
    float riskDistance = math.abs(entryPrice - stopPrice)
    float expectedMovePercent = entryPrice > 0 ? rewardDistance / entryPrice * 100 : 0
    float riskRewardRatio = riskDistance > 0 ? rewardDistance / riskDistance : 0
    float confidenceMultiplier = confidenceSizeMultiplier(confidence)
    float scoreMultiplier = scoreSizeMultiplier(selectionScore)
    float rewardPct = entryPrice > 0 ? rewardDistance / entryPrice : 0
    float riskPct = entryPrice > 0 ? riskDistance / entryPrice : 0
    float targetProfitUsd = (targetProfitMinUsd + targetProfitMaxUsd) / 2
    float profitFirstRawSize = rewardPct > 0 ? targetProfitUsd / rewardPct * confidenceMultiplier * scoreMultiplier : 0
    float riskFirstRawSize = riskPct > 0 ? maxRiskPerTradeUsd / riskPct : 0
    float rawSize = positionSizingMode == "RISK_FIRST" ? riskFirstRawSize : math.min(profitFirstRawSize, riskFirstRawSize)
    float boundedSize = math.min(math.max(rawSize, minPositionUsd), maxPositionUsd)
    float expectedLossUsd = boundedSize * riskPct
    float expectedProfitUsd = positionSizingMode == "RISK_FIRST" ? expectedLossUsd * targetRMultiple : boundedSize * rewardPct
    float riskUtilization = maxRiskPerTradeUsd > 0 ? expectedLossUsd / maxRiskPerTradeUsd * 100 : 0
    bool validPrices = entryPrice > 0 and targetPrice > 0 and stopPrice > 0
    bool accepted = validPrices and rewardDistance > 0 and riskDistance > 0 and riskRewardRatio >= minRiskRewardRatio and expectedLossUsd <= maxRiskPerTradeUsd + 0.0001 and expectedProfitUsd >= targetProfitMinUsd and expectedProfitUsd <= targetProfitMaxUsd + 0.0001
    string rejection = not validPrices ? "Invalid entry, target, or stop price" : rewardDistance <= 0 or riskDistance <= 0 ? "Reward and risk distances must be greater than zero" : riskRewardRatio < minRiskRewardRatio ? "RR too low" : expectedLossUsd > maxRiskPerTradeUsd + 0.0001 ? "Risk above max" : expectedProfitUsd < targetProfitMinUsd ? "Profit below target" : expectedProfitUsd > targetProfitMaxUsd + 0.0001 ? "Profit above target" : ""
    [accepted, rejection, expectedMovePercent, rewardDistance, riskDistance, riskRewardRatio, roundMoney(boundedSize), roundMoney(expectedProfitUsd), roundMoney(expectedLossUsd), riskUtilization, riskUtilization < 50 ? 1.0 : 0.0]

drawTradeManagement(string signal, float entryPrice, float targetPrice, float stopPrice, string targetMode, string targetSource, float positionSize, float expectedProfit, float expectedLoss, float rr) =>
    color tradeColor = signal == "BUY" ? color.lime : color.red
    color tpColor = targetLineColor(targetMode)
    line entryLine = line.new(bar_index, entryPrice, bar_index + 40, entryPrice, color = color.new(color.white, 20), style = line.style_dotted)
    line targetLine = line.new(bar_index, targetPrice, bar_index + 40, targetPrice, color = color.new(tpColor, 0), width = 2)
    line stopLine = line.new(bar_index, stopPrice, bar_index + 40, stopPrice, color = hardStopEnabled ? color.new(color.red, 0) : color.new(color.yellow, 0), width = hardStopEnabled ? 2 : 1, style = line.style_dashed)
    string labelText = "TP " + targetMode + "\n" + str.tostring(targetPrice, format.mintick) + "\nSL " + str.tostring(stopPrice, format.mintick)
    label tradeLabel = uiDebug ? label.new(bar_index, targetPrice, labelText, style = signal == "BUY" ? label.style_label_down : label.style_label_up, color = color.new(tradeColor, 0), textcolor = color.white, size = size.tiny) : na
    [entryLine, targetLine, stopLine, tradeLabel]

pruneOldestZone() =>
    box oldBox = array.shift(zoneBoxes)
    if not na(oldBox)
        box.delete(oldBox)
    line oldMidLine = array.shift(midpointLines)
    if not na(oldMidLine)
        line.delete(oldMidLine)
    array.shift(zoneHighs)
    array.shift(zoneLows)
    array.shift(zoneMidpoints)
    array.shift(zoneDirections)
    array.shift(zoneTypes)
    array.shift(zoneIds)
    array.shift(zoneRangeMultiples)
    array.shift(zoneCreatedBars)
    array.shift(zoneInvalidated)
    array.shift(zoneFilled)
    array.shift(zoneFlipped)
    array.shift(zoneReacted)

addZone(string zoneType, string direction, float zoneLow, float zoneHigh, int leftBar, string reasonText, float zoneRangeMultiple) =>
    while array.size(zoneHighs) >= maxTrackedZones
        pruneOldestZone()
    float midpoint = (zoneLow + zoneHigh) / 2
    string zoneId = zoneType + ":" + direction + ":" + str.tostring(leftBar) + ":" + str.tostring(zoneLow, format.mintick) + ":" + str.tostring(zoneHigh, format.mintick)
    string boxText = zoneBoxText(zoneType, direction, zoneLow, zoneHigh, midpoint, reasonText)
    color borderColor = direction == "BULLISH" ? color.new(color.lime, 0) : color.new(color.red, 0)
    color fillColor = direction == "BULLISH" ? color.new(color.lime, 88) : color.new(color.red, 88)
    box zoneBox = box.new(left = leftBar, top = zoneHigh, right = bar_index + activePreviewBars, bottom = zoneLow, border_color = showRawZones ? borderColor : color.new(borderColor, 100), bgcolor = showRawZones ? fillColor : color.new(fillColor, 100))
    if zoneTextMode != "Off"
        box.set_text(zoneBox, boxText)
        box.set_text_color(zoneBox, color.white)
        box.set_text_size(zoneBox, size.tiny)
        box.set_text_halign(zoneBox, text.align_left)
        box.set_text_valign(zoneBox, text.align_center)
    line midLine = uiDebug ? line.new(x1 = leftBar, y1 = midpoint, x2 = bar_index + activePreviewBars, y2 = midpoint, color = showRawZones ? color.new(borderColor, 25) : color.new(borderColor, 100), style = line.style_dashed) : na
    array.push(zoneBoxes, zoneBox)
    array.push(midpointLines, midLine)
    array.push(zoneHighs, zoneHigh)
    array.push(zoneLows, zoneLow)
    array.push(zoneMidpoints, midpoint)
    array.push(zoneDirections, direction)
    array.push(zoneTypes, zoneType)
    array.push(zoneIds, zoneId)
    array.push(zoneRangeMultiples, zoneRangeMultiple)
    array.push(zoneCreatedBars, bar_index)
    array.push(zoneInvalidated, false)
    array.push(zoneFilled, false)
    array.push(zoneFlipped, false)
    array.push(zoneReacted, false)

float bullishLow = c1High
float bullishHigh = c3Low
float bullishMid = (bullishLow + bullishHigh) / 2
bool bullishPdOk = premiumDiscountOk("BULLISH", bullishMid)
bool validBullishFvg = rawBullishFvg and bullLiquiditySweep and displacementBullish and bullMss and bullishPdOk and sessionOk

float bearishLow = c3High
float bearishHigh = c1Low
float bearishMid = (bearishLow + bearishHigh) / 2
bool bearishPdOk = premiumDiscountOk("BEARISH", bearishMid)
bool validBearishFvg = rawBearishFvg and bearLiquiditySweep and displacementBearish and bearMss and bearishPdOk and sessionOk

if validBullishFvg
    addZone("FVG", "BULLISH", bullishLow, bullishHigh, bar_index - 2, "sell-side sweep + displacement + MSS", rangeMultiple)

if validBearishFvg
    addZone("FVG", "BEARISH", bearishLow, bearishHigh, bar_index - 2, "buy-side sweep + displacement + MSS", rangeMultiple)

if showRejectedRawFvgs and rawBullishFvg and not validBullishFvg
    string reason = rejectionReason("BULLISH", bullLiquiditySweep, displacementBullish, bullMss, bullishPdOk, sessionOk)
    label.new(bar_index, low, "Rejected bullish FVG\n" + reason, style = label.style_label_up, color = color.new(color.gray, 25), textcolor = color.white, size = size.tiny)

if showRejectedRawFvgs and rawBearishFvg and not validBearishFvg
    string reason = rejectionReason("BEARISH", bearLiquiditySweep, displacementBearish, bearMss, bearishPdOk, sessionOk)
    label.new(bar_index, high, "Rejected bearish FVG\n" + reason, style = label.style_label_down, color = color.new(color.gray, 25), textcolor = color.white, size = size.tiny)

float bestScore = na
float bestConfidence = na
string bestSignal = "NONE"
string bestZoneType = "--"
string bestZoneId = "--"
string bestReason = "No candidate qualified"
float bestZoneHigh = na
float bestZoneLow = na
int bestZoneIndex = na
float bestTargetReachProbability = na
string bestReactionTier = "--"
string bestReactionWinner = "--"
float bestReactionScore = na
float bestReactionTierScore = na
float bestDisplacementScore = na
float bestRrFitScore = na
float bestScalpTargetFitScore = na
float bestTargetDistancePenalty = na
float bestZoneFreshnessScore = na
float bestSelectedTarget = na
string bestTargetMode = "--"
string bestTargetSource = "--"
float bestExpectedProfitUsd = na
float bestExpectedLossUsd = na
float bestRiskRewardRatio = na
string bestRankingText = "--"
string bestSelectionReason = "--"
string runnerUpText = "--"

int zoneCount = array.size(zoneHighs)
if zoneCount > 0
    int firstZoneIndex = math.max(0, zoneCount - maxEvaluatedZones)
    for i = firstZoneIndex to zoneCount - 1
        float zHigh = array.get(zoneHighs, i)
        float zLow = array.get(zoneLows, i)
        float zMid = array.get(zoneMidpoints, i)
        string zDirection = array.get(zoneDirections, i)
        string zType = array.get(zoneTypes, i)
        string zId = array.get(zoneIds, i)
        float zRangeMultiple = array.get(zoneRangeMultiples, i)
        int zCreatedBar = array.get(zoneCreatedBars, i)
        bool invalidated = array.get(zoneInvalidated, i)
        bool filled = array.get(zoneFilled, i)
        bool flipped = array.get(zoneFlipped, i)
        bool reacted = array.get(zoneReacted, i)
        box zBox = array.get(zoneBoxes, i)
        line zMidLine = array.get(midpointLines, i)

        bool touchedZone = low <= zHigh and high >= zLow
        bool touchedMid = low <= zMid and high >= zMid
        string midpointResult = not touchedMid ? "NOT_EVALUATED" : close > zMid ? "BULLISH" : close < zMid ? "BEARISH" : "NEUTRAL"
        string boundaryResult = close > zHigh ? "BULLISH" : close < zLow ? "BEARISH" : "NEUTRAL"
        string reactionTier = reactionTierOf(zDirection, touchedZone, touchedMid, currentDisplacement, zHigh, zLow, zMid)
        string reactionWinner = reactionWinnerOf(zDirection, reactionTier, zHigh, zLow, zMid)
        float reactionScore = reactionScoreOf(reactionTier)
        bool bodyCloseConfirms = (reactionWinner == "BUY" and close > open and close >= zMid) or (reactionWinner == "SELL" and close < open and close <= zMid)
        bool reactionConfirmed = bar_index > zCreatedBar and touchedZone and bodyCloseConfirms and reactionWinner != "NONE"
        bool newFilled = zDirection == "BULLISH" ? low <= zLow : high >= zHigh
        bool newInvalidated = zDirection == "BULLISH" ? close < zLow : close > zHigh

        if uiDebug and showScoreBreakdown and touchedZone and bar_index > zCreatedBar and not invalidated
            color reactionColor = reactionTier == "DISPLACEMENT" ? (reactionWinner == "BUY" ? color.lime : color.red) : reactionTier == "BOUNDARY" ? (reactionWinner == "BUY" ? color.green : color.maroon) : reactionTier == "MIDPOINT" ? color.yellow : color.gray
            string reactionText = "Reaction:\n" + reactionTier
            label.new(bar_index, reactionWinner == "SELL" ? high : low, reactionText, style = reactionWinner == "SELL" ? label.style_label_down : label.style_label_up, color = color.new(reactionColor, 0), textcolor = reactionTier == "MIDPOINT" ? color.black : color.white, size = reactionTier == "DISPLACEMENT" ? size.small : size.tiny)

        if not reacted and not invalidated
            int visibleRightBar = math.max(bar_index, zCreatedBar + minVisibleZoneBars)
            int rightBar = stopZonesAtReaction and reactionConfirmed ? visibleRightBar : bar_index + activePreviewBars
            box.set_right(zBox, rightBar)
            if not na(zMidLine)
                line.set_x2(zMidLine, rightBar)

        if stopZonesAtReaction and reactionConfirmed and not reacted
            array.set(zoneReacted, i, true)
            box.set_border_color(zBox, color.new(zDirection == "BULLISH" ? color.lime : color.red, 0))
            if zoneTextMode == "Compact"
                box.set_text(zBox, zType + " " + (zDirection == "BULLISH" ? "BULL" : "BEAR") + "\nReacted")
            else if zoneTextMode == "Full"
                box.set_text(zBox, zType + " " + zDirection + "\nREACTION\nH: " + str.tostring(zHigh, format.mintick) + "\nL: " + str.tostring(zLow, format.mintick) + "\nM: " + str.tostring(zMid, format.mintick))

        if newFilled and not filled
            array.set(zoneFilled, i, true)

        if newInvalidated and not invalidated
            array.set(zoneInvalidated, i, true)
            box.set_bgcolor(zBox, color.new(color.gray, 88))
            box.set_border_color(zBox, color.new(color.gray, 25))
            if not reacted
                int invalidatedRightBar = math.max(bar_index, zCreatedBar + minVisibleZoneBars)
                box.set_right(zBox, invalidatedRightBar)
                if not na(zMidLine)
                    line.set_x2(zMidLine, invalidatedRightBar)
            if zoneTextMode != "Off"
                box.set_text(zBox, zType + " " + zDirection + "\nINVALIDATED\nH: " + str.tostring(zHigh, format.mintick) + "\nL: " + str.tostring(zLow, format.mintick) + "\nM: " + str.tostring(zMid, format.mintick))
                box.set_text_color(zBox, color.new(color.white, 10))
            if not na(zMidLine)
                line.set_color(zMidLine, color.new(color.gray, 25))

            if zType == "FVG" and not flipped
                array.set(zoneFlipped, i, true)
                string ifvgDirection = zDirection == "BULLISH" ? "BEARISH" : "BULLISH"
                addZone("IFVG", ifvgDirection, zLow, zHigh, bar_index, "source FVG invalidated", array.get(zoneRangeMultiples, i))
                if tradeOnIfvgFormation
                    string formationSignal = ifvgDirection == "BULLISH" ? "BUY" : "SELL"
                    float formationConfidence = 100
                    float formationEntry = close
                    float formationStop = formationSignal == "BUY" ? zLow : zHigh
                    [formationOpposingTarget, formationOpposingTargetIndex] = findOpposingTarget(formationSignal, formationEntry)
                    float formationSwingTarget = fallbackSwingTarget(formationSignal, formationEntry)
                    float formationRiskDistance = math.abs(formationEntry - formationStop)
                    float formationScalpTarget = formationSignal == "BUY" ? formationEntry + formationRiskDistance * targetRMultiple : formationEntry - formationRiskDistance * targetRMultiple
                    float formationStructureTarget = not na(formationOpposingTarget) ? formationOpposingTarget : formationSwingTarget
                    bool formationStructureValid = formationSignal == "BUY" ? formationStructureTarget > formationEntry : formationStructureTarget < formationEntry
                    float formationStructureRr = formationRiskDistance > 0 ? math.abs(formationStructureTarget - formationEntry) / formationRiskDistance : na
                    bool formationStructureQualified = formationStructureValid and not na(formationStructureRr) and formationStructureRr >= minRiskRewardRatio
                    float formationSelectedTarget = exitTargetMode == "SCALP" ? formationScalpTarget : exitTargetMode == "STRUCTURE" ? formationStructureTarget : formationStructureQualified and math.abs(formationStructureTarget - formationEntry) <= math.abs(formationScalpTarget - formationEntry) ? formationStructureTarget : formationScalpTarget
                    string formationTargetSource = exitTargetMode == "SCALP" ? "SCALP" : exitTargetMode == "STRUCTURE" ? "STRUCTURE" : (not na(formationOpposingTarget) ? "HYBRID Opposing FVG" : "HYBRID Swing")
                    float formationRewardDistance = math.abs(formationSelectedTarget - formationEntry)
                    float formationRr = formationRiskDistance > 0 ? formationRewardDistance / formationRiskDistance : na
                    float formationRiskPct = formationEntry > 0 ? formationRiskDistance / formationEntry : 0
                    float formationPositionSize = formationRiskPct > 0 ? math.min(math.max(maxRiskPerTradeUsd / formationRiskPct, minPositionUsd), maxPositionUsd) : 0
                    float formationExpectedLoss = formationPositionSize * formationRiskPct
                    float formationExpectedProfit = formationExpectedLoss * targetRMultiple
                    bool formationTargetValid = formationSignal == "BUY" ? formationSelectedTarget > formationEntry : formationSelectedTarget < formationEntry
                    bool formationStopValid = formationSignal == "BUY" ? formationStop < formationEntry : formationStop > formationEntry
                    bool formationTargetOk = formationTargetValid and formationStopValid and formationExpectedProfit >= minExpectedProfitUsd and formationRr >= minRiskRewardRatio
                    bool formationConfidenceOk = formationConfidence >= ictMinConfidence
                    float formationTargetFitScore = formationExpectedProfit >= preferredMinProfitUsd and formationExpectedProfit <= preferredMaxProfitUsd ? 25 : formationTargetOk ? 15 : 0
                    float formationScore = formationTargetOk and formationConfidenceOk ? math.round((formationConfidence * 0.45 + 14 + formationTargetFitScore + 12) * 100) / 100 : 0
                    float formationReactionTierScore = 30
                    float formationDisplacementScore = displacementScoreOf(array.get(zoneRangeMultiples, i), "DISPLACEMENT")
                    float formationRrFitScore = rrFitScoreOf(formationRr)
                    float formationScalpTargetFitScore = scalpTargetFitScoreOf(formationExpectedProfit)
                    float formationFreshnessScore = zoneFreshnessScoreOf(bar_index)
                    float formationMovePct = formationEntry > 0 ? formationRewardDistance / formationEntry * 100 : 0
                    float formationPenalty = targetDistancePenaltyOf(formationMovePct, exitTargetMode)
                    float formationProbability = clampScore(roundScore(formationReactionTierScore + formationDisplacementScore + formationRrFitScore + formationScalpTargetFitScore + formationFreshnessScore - formationPenalty))
                    bool formationBetter = na(bestTargetReachProbability) or formationProbability > bestTargetReachProbability or (formationProbability == bestTargetReachProbability and formationDisplacementScore > bestDisplacementScore) or (formationProbability == bestTargetReachProbability and formationDisplacementScore == bestDisplacementScore and formationRrFitScore > bestRrFitScore) or (formationProbability == bestTargetReachProbability and formationDisplacementScore == bestDisplacementScore and formationRrFitScore == bestRrFitScore and formationReactionTierScore > bestReactionTierScore) or (formationProbability == bestTargetReachProbability and formationDisplacementScore == bestDisplacementScore and formationRrFitScore == bestRrFitScore and formationReactionTierScore == bestReactionTierScore and formationScore > bestScore) or (formationProbability == bestTargetReachProbability and formationDisplacementScore == bestDisplacementScore and formationRrFitScore == bestRrFitScore and formationReactionTierScore == bestReactionTierScore and formationScore == bestScore and formationConfidence > bestConfidence)
                    if formationTargetOk and formationConfidenceOk and formationReactionTierScore > 0 and formationBetter
                        bool formationHadPreviousBest = not na(bestTargetReachProbability)
                        if not na(bestTargetReachProbability)
                            runnerUpText := "2. " + bestSignal + " " + bestZoneType + "\nProb=" + str.tostring(bestTargetReachProbability, "#.##") + "\nScore=" + str.tostring(bestScore, "#.##")
                        bestScore := formationScore
                        bestConfidence := formationConfidence
                        bestSignal := formationSignal
                        bestZoneType := "IFVG"
                        bestZoneId := "IFVG:" + ifvgDirection + ":" + zId
                        bestZoneHigh := zHigh
                        bestZoneLow := zLow
                        bestZoneIndex := array.size(zoneHighs) - 1
                        bestTargetReachProbability := formationProbability
                        bestReactionTier := "DISPLACEMENT"
                        bestReactionWinner := formationSignal
                        bestReactionScore := 100
                        bestReactionTierScore := formationReactionTierScore
                        bestDisplacementScore := formationDisplacementScore
                        bestRrFitScore := formationRrFitScore
                        bestScalpTargetFitScore := formationScalpTargetFitScore
                        bestTargetDistancePenalty := formationPenalty
                        bestZoneFreshnessScore := formationFreshnessScore
                        bestSelectedTarget := formationSelectedTarget
                        bestTargetMode := exitTargetMode
                        bestTargetSource := formationTargetSource
                        bestExpectedProfitUsd := formationExpectedProfit
                        bestExpectedLossUsd := formationExpectedLoss
                        bestRiskRewardRatio := formationRr
                        bestRankingText := "1. " + formationSignal + " IFVG\nProb=" + str.tostring(formationProbability, "#.##") + "\nScore=" + str.tostring(formationScore, "#.##")
                        bestSelectionReason := formationHadPreviousBest ? "Higher probability" : "First qualified candidate"
                        bestReason := formationSignal + " fresh IFVG formation, score=" + str.tostring(formationScore) + ", confidence=100"

        float confidence = reactionScore
        string signal = reactionConfirmed and not invalidated and not reacted ? reactionWinner : "NONE"
        float entryForCandidate = close
        float candidateStop = signal == "BUY" ? zLow : zHigh
        [candidateOpposingTarget, candidateOpposingTargetIndex] = findOpposingTarget(signal, entryForCandidate)
        float candidateSwingTarget = fallbackSwingTarget(signal, entryForCandidate)
        float candidateRiskDistance = math.abs(entryForCandidate - candidateStop)
        float candidateScalpTarget = signal == "BUY" ? entryForCandidate + candidateRiskDistance * targetRMultiple : entryForCandidate - candidateRiskDistance * targetRMultiple
        float candidateStructureTarget = not na(candidateOpposingTarget) ? candidateOpposingTarget : candidateSwingTarget
        bool candidateStructureValid = signal == "BUY" ? candidateStructureTarget > entryForCandidate : signal == "SELL" ? candidateStructureTarget < entryForCandidate : false
        float candidateStructureRr = candidateRiskDistance > 0 ? math.abs(candidateStructureTarget - entryForCandidate) / candidateRiskDistance : na
        bool candidateStructureQualified = candidateStructureValid and not na(candidateStructureRr) and candidateStructureRr >= minRiskRewardRatio
        float candidateTarget = exitTargetMode == "SCALP" ? candidateScalpTarget : exitTargetMode == "STRUCTURE" ? candidateStructureTarget : candidateStructureQualified and math.abs(candidateStructureTarget - entryForCandidate) <= math.abs(candidateScalpTarget - entryForCandidate) ? candidateStructureTarget : candidateScalpTarget
        string candidateTargetSource = exitTargetMode == "SCALP" ? "SCALP" : exitTargetMode == "STRUCTURE" ? "STRUCTURE" : (not na(candidateOpposingTarget) ? "HYBRID Opposing FVG" : "HYBRID Swing")
        bool targetIsValidCandidate = signal == "BUY" ? candidateTarget > entryForCandidate : signal == "SELL" ? candidateTarget < entryForCandidate : false
        bool stopIsValidCandidate = signal == "BUY" ? candidateStop < entryForCandidate : signal == "SELL" ? candidateStop > entryForCandidate : false
        float candidateRewardDistance = math.abs(candidateTarget - entryForCandidate)
        float candidateRr = candidateRiskDistance > 0 ? candidateRewardDistance / candidateRiskDistance : na
        float candidateRiskPct = entryForCandidate > 0 ? candidateRiskDistance / entryForCandidate : 0
        float candidatePositionSize = candidateRiskPct > 0 ? math.min(math.max(maxRiskPerTradeUsd / candidateRiskPct, minPositionUsd), maxPositionUsd) : 0
        float expectedLoss = candidatePositionSize * candidateRiskPct
        float expectedProfit = expectedLoss * targetRMultiple
        bool targetOk = expectedProfit >= minExpectedProfitUsd
        bool confidenceOk = confidence >= ictMinConfidence
        bool tierOk = reactionTier != "TOUCH" and reactionTier != "NONE"
        bool rrOk = not na(candidateRr) and candidateRr >= minRiskRewardRatio
        bool qualified = signal != "NONE" and confidenceOk and targetOk and tierOk and rrOk and targetIsValidCandidate and stopIsValidCandidate
        float targetFitScore = expectedProfit >= preferredMinProfitUsd and expectedProfit <= preferredMaxProfitUsd ? 25 : targetOk ? 15 : 0
        float zoneQualityScore = zType == "IFVG" ? 14 : 10
        float legacyReactionScore = touchedZone and bodyCloseConfirms ? 12 : (touchedZone ? 3 : 0) + (touchedMid ? 2 : 0) + (bodyCloseConfirms ? 3 : 0)
        float score = qualified ? math.round((confidence * 0.45 + zoneQualityScore + targetFitScore + legacyReactionScore) * 100) / 100 : 0
        float reactionTierScore = reactionTierScoreOf(reactionTier)
        float displacementScore = displacementScoreOf(zRangeMultiple, reactionTier)
        float rrFitScore = rrFitScoreOf(candidateRr)
        float scalpFitScore = scalpTargetFitScoreOf(expectedProfit)
        float freshnessScore = zoneFreshnessScoreOf(zCreatedBar)
        float expectedMovePctForProbability = entryForCandidate > 0 ? candidateRewardDistance / entryForCandidate * 100 : 0
        float distancePenalty = targetDistancePenaltyOf(expectedMovePctForProbability, exitTargetMode)
        float probability = clampScore(roundScore(reactionTierScore + displacementScore + rrFitScore + scalpFitScore + freshnessScore - distancePenalty))

        bool betterCandidate = na(bestTargetReachProbability) or probability > bestTargetReachProbability or (probability == bestTargetReachProbability and displacementScore > bestDisplacementScore) or (probability == bestTargetReachProbability and displacementScore == bestDisplacementScore and rrFitScore > bestRrFitScore) or (probability == bestTargetReachProbability and displacementScore == bestDisplacementScore and rrFitScore == bestRrFitScore and reactionTierScore > bestReactionTierScore) or (probability == bestTargetReachProbability and displacementScore == bestDisplacementScore and rrFitScore == bestRrFitScore and reactionTierScore == bestReactionTierScore and score > bestScore) or (probability == bestTargetReachProbability and displacementScore == bestDisplacementScore and rrFitScore == bestRrFitScore and reactionTierScore == bestReactionTierScore and score == bestScore and confidence > bestConfidence)
        if qualified and betterCandidate
            bool candidateHadPreviousBest = not na(bestTargetReachProbability)
            if not na(bestTargetReachProbability)
                runnerUpText := "2. " + bestSignal + " " + bestZoneType + "\nProb=" + str.tostring(bestTargetReachProbability, "#.##") + "\nScore=" + str.tostring(bestScore, "#.##")
            bestScore := score
            bestConfidence := confidence
            bestSignal := signal
            bestZoneType := zType
            bestZoneId := zId
            bestZoneHigh := zHigh
            bestZoneLow := zLow
            bestZoneIndex := i
            bestTargetReachProbability := probability
            bestReactionTier := reactionTier
            bestReactionWinner := reactionWinner
            bestReactionScore := reactionScore
            bestReactionTierScore := reactionTierScore
            bestDisplacementScore := displacementScore
            bestRrFitScore := rrFitScore
            bestScalpTargetFitScore := scalpFitScore
            bestTargetDistancePenalty := distancePenalty
            bestZoneFreshnessScore := freshnessScore
            bestSelectedTarget := candidateTarget
            bestTargetMode := exitTargetMode
            bestTargetSource := candidateTargetSource
            bestExpectedProfitUsd := expectedProfit
            bestExpectedLossUsd := expectedLoss
            bestRiskRewardRatio := candidateRr
            bestRankingText := "1. " + signal + " " + zType + "\nProb=" + str.tostring(probability, "#.##") + "\nScore=" + str.tostring(score, "#.##")
            bestSelectionReason := candidateHadPreviousBest ? "Higher probability" : "First qualified candidate"
            bestReason := signal + " reaction confirmed, tier=" + reactionTier + ", probability=" + str.tostring(probability, "#.##") + ", score=" + str.tostring(score) + ", confidence=" + str.tostring(confidence, "#.##")

        if signal != "NONE" and not qualified and showRejectedZones and uiDebug
            box.set_bgcolor(zBox, color.new(color.gray, 94))
            box.set_border_color(zBox, color.new(color.gray, 70))

latestSignal := bestSignal
latestZoneType := bestZoneType
latestZoneId := bestZoneId
latestConfidence := bestConfidence
latestScore := bestScore
latestReason := bestReason
latestZoneHigh := bestZoneHigh
latestZoneLow := bestZoneLow
latestTargetReachProbability := bestTargetReachProbability
latestReactionTier := bestReactionTier
latestReactionWinner := bestReactionWinner
latestReactionScore := bestReactionScore
latestReactionTierScore := bestReactionTierScore
latestDisplacementScore := bestDisplacementScore
latestRrFitScore := bestRrFitScore
latestScalpTargetFitScore := bestScalpTargetFitScore
latestTargetDistancePenalty := bestTargetDistancePenalty
latestZoneFreshnessScore := bestZoneFreshnessScore
latestSelectedTarget := bestSelectedTarget
latestTargetMode := bestTargetMode
latestTargetSource := bestTargetSource
latestRankingText := runnerUpText == "--" ? bestRankingText : bestRankingText + "\n\n" + runnerUpText
latestSelectionReason := bestSelectionReason

if not na(bestZoneIndex) and bestZoneIndex >= 0 and bestZoneIndex < array.size(zoneBoxes)
    box selectedBox = array.get(zoneBoxes, bestZoneIndex)
    color selectedColor = bestSignal == "BUY" ? color.lime : color.red
    box.set_bgcolor(selectedBox, showRawZones ? color.new(selectedColor, 78) : color.new(selectedColor, 100))
    box.set_border_color(selectedBox, color.new(selectedColor, 0))
    if showSelected and showLabels and uiVerbose and barstate.isconfirmed and latestSignal != "NONE"
        label.new(bar_index, latestSignal == "BUY" ? low : high, "SELECTED\n" + latestZoneType + "\nProb " + str.tostring(latestTargetReachProbability, "#.##") + "%\nReaction " + latestReactionTier + "\nScore " + str.tostring(latestScore, "#.##") + "\nConf " + str.tostring(latestConfidence, "#.##"), style = latestSignal == "BUY" ? label.style_label_up : label.style_label_down, color = color.new(color.blue, 0), textcolor = color.white, size = size.small)

bool newManagedSignal = showTradeManagement and latestSignal != "NONE" and barstate.isconfirmed
if newManagedSignal
    float entryPrice = close
    [opposingTarget, opposingTargetIndex] = findOpposingTarget(latestSignal, entryPrice)
    float swingTarget = fallbackSwingTarget(latestSignal, entryPrice)
    float selectedStop = latestSignal == "BUY" ? latestZoneLow : latestZoneHigh
    float riskDistanceForScalp = math.abs(entryPrice - selectedStop)
    float scalpTarget = latestSignal == "BUY" ? entryPrice + riskDistanceForScalp * targetRMultiple : entryPrice - riskDistanceForScalp * targetRMultiple
    float structureTarget = not na(opposingTarget) ? opposingTarget : swingTarget
    bool structureValid = latestSignal == "BUY" ? structureTarget > entryPrice : structureTarget < entryPrice
    float structureRr = riskDistanceForScalp > 0 ? math.abs(structureTarget - entryPrice) / riskDistanceForScalp : na
    bool structureQualified = structureValid and not na(structureRr) and structureRr >= minRiskRewardRatio
    float selectedTarget = not na(latestSelectedTarget) ? latestSelectedTarget : exitTargetMode == "SCALP" ? scalpTarget : exitTargetMode == "STRUCTURE" ? structureTarget : structureQualified and math.abs(structureTarget - entryPrice) <= math.abs(scalpTarget - entryPrice) ? structureTarget : scalpTarget
    string selectedTargetSource = latestTargetSource != "--" ? latestTargetSource : exitTargetMode == "SCALP" ? "SCALP" : exitTargetMode == "STRUCTURE" ? "STRUCTURE" : (not na(opposingTarget) ? "HYBRID Opposing FVG" : "HYBRID Swing")
    bool targetIsValid = latestSignal == "BUY" ? selectedTarget > entryPrice : selectedTarget < entryPrice
    bool stopIsValid = latestSignal == "BUY" ? selectedStop < entryPrice : selectedStop > entryPrice
    bool canEvaluateSizing = not na(selectedTarget) and targetIsValid and not na(selectedStop) and stopIsValid and not na(latestConfidence) and not na(latestScore)
    if canEvaluateSizing
        [sizingAccepted, sizingReason, expectedMovePct, rewardDistance, riskDistance, riskReward, positionSize, expectedProfitUsd, expectedLossUsd, riskUtilization, riskWarningFlag] = calculateSizing(latestConfidence, latestScore, entryPrice, selectedTarget, selectedStop)
        latestSizingAccepted := sizingAccepted
        latestSizingReason := sizingAccepted ? "ACCEPTED" : sizingReason
        latestSkipReason := sizingAccepted ? "--" : skipReasonFor(targetIsValid, stopIsValid, sizingAccepted, sizingReason, latestTargetReachProbability, riskReward)
        latestPositionSizeUsd := positionSize
        latestExpectedProfitUsd := expectedProfitUsd
        latestExpectedLossUsd := expectedLossUsd
        latestRiskRewardRatio := riskReward
        latestRiskUtilizationPercent := riskUtilization
        latestRiskUtilizationWarning := riskWarningFlag > 0
        latestHardStopPrice := selectedStop
        latestExpectedMovePercent := expectedMovePct
        latestRewardDistance := rewardDistance
        latestRiskDistance := riskDistance
        latestSelectedTarget := selectedTarget
        latestTargetMode := exitTargetMode
        latestTargetSource := selectedTargetSource
        if not sizingAccepted
            if showSkips and showLabels and uiVerbose
                label.new(bar_index, high, "ENTRY SKIP\n" + latestSkipReason + "\nRR " + str.tostring(riskReward, "#.##") + "\n+$" + str.tostring(expectedProfitUsd, "#.##") + " / -$" + str.tostring(expectedLossUsd, "#.##"), style = latestSignal == "BUY" ? label.style_label_up : label.style_label_down, color = color.new(color.gray, 0), textcolor = color.white, size = size.small)
    else if latestSignal != "NONE"
        latestSizingAccepted := false
        latestSizingReason := "Invalid target or stop"
        latestSkipReason := skipReasonFor(targetIsValid, stopIsValid, false, "Invalid target or stop", latestTargetReachProbability, na)
        latestPositionSizeUsd := na
        latestExpectedProfitUsd := na
        latestExpectedLossUsd := na
        latestRiskRewardRatio := na
        latestRiskUtilizationPercent := na
        latestRiskUtilizationWarning := false
        latestHardStopPrice := selectedStop
        latestExpectedMovePercent := na
        latestRewardDistance := na
        latestRiskDistance := na
        if showSkips and showLabels and uiVerbose
            label.new(bar_index, high, "ENTRY SKIP\n" + latestSkipReason + "\nRR --\nExpected --", style = latestSignal == "BUY" ? label.style_label_up : label.style_label_down, color = color.new(color.gray, 0), textcolor = color.white, size = size.small)
    if canEvaluateSizing and latestSizingAccepted
        if not keepHistoricalTradeLines and not na(activeEntryLine)
            line.delete(activeEntryLine)
        if not keepHistoricalTradeLines and not na(activeTargetLine)
            line.delete(activeTargetLine)
        if not keepHistoricalTradeLines and not na(activeStopLine)
            line.delete(activeStopLine)
        if not keepHistoricalTradeLines and not na(activeTradeLabel)
            label.delete(activeTradeLabel)
        [newEntryLine, newTargetLine, newStopLine, newTradeLabel] = drawTradeManagement(latestSignal, entryPrice, selectedTarget, selectedStop, exitTargetMode, selectedTargetSource, latestPositionSizeUsd, latestExpectedProfitUsd, latestExpectedLossUsd, latestRiskRewardRatio)
        activeTrade := true
        activeTradeDirection := latestSignal
        activeEntry := entryPrice
        activeTarget := selectedTarget
        activeInitialStop := selectedStop
        activeTargetSource := selectedTargetSource
        activeEntryBarIndex := bar_index
        activeEntryTime := str.format_time(time, "yyyy-MM-dd HH:mm", "UTC")
        activeTargetZoneIndex := opposingTargetIndex
        activeStopAtBe := false
        activeEntryLine := newEntryLine
        activeTargetLine := newTargetLine
        activeStopLine := newStopLine
        activeTradeLabel := newTradeLabel
        latestEntryBarIndex := bar_index
        latestEntryPrice := entryPrice
        latestEntryTime := activeEntryTime
        if showEntryHighlight
            activeEntryMarkerLine := line.new(bar_index, low, bar_index, high, extend = extend.both, color = color.new(latestSignal == "BUY" ? color.lime : color.red, 20), style = line.style_dotted)

if showTradeManagement and activeTrade
    bool targetHit = activeTradeDirection == "BUY" ? high >= activeTarget : low <= activeTarget
    bool opposingZonePrinted = activeTradeDirection == "BUY" ? validBearishFvg and bearishLow > activeEntry : validBullishFvg and bullishHigh < activeEntry
    bool activeTargetIsOpposing = activeTargetSource == "Opposing FVG" or activeTargetSource == "HYBRID Opposing FVG"
    bool targetDisrespected = activeTargetIsOpposing and targetZoneDisrespected(activeTradeDirection, activeTargetZoneIndex)
    bool opposingTargetTouched = activeTargetIsOpposing and targetHit

    if targetDisrespected
        float swingRetarget = fallbackSwingTarget(activeTradeDirection, activeEntry)
        bool retargetValid = activeTradeDirection == "BUY" ? swingRetarget > activeEntry : swingRetarget < activeEntry
        if not na(swingRetarget) and retargetValid
            activeTarget := swingRetarget
            activeTargetSource := "STRUCTURE Swing"
            activeTargetZoneIndex := na
            line.set_y1(activeTargetLine, activeTarget)
            line.set_y2(activeTargetLine, activeTarget)
            if not na(activeTradeLabel)
                label.set_y(activeTradeLabel, activeTarget)
                label.set_text(activeTradeLabel, "TP STRUCTURE\n" + str.tostring(activeTarget, format.mintick))
            targetHit := activeTradeDirection == "BUY" ? high >= activeTarget : low <= activeTarget

    if (targetHit or opposingZonePrinted or opposingTargetTouched) and not activeStopAtBe
        activeStopAtBe := true
        line.set_y1(activeStopLine, activeEntry)
        line.set_y2(activeStopLine, activeEntry)
        line.set_color(activeStopLine, color.new(color.aqua, 0))
        label.new(bar_index, activeEntry, "SL -> BE", style = activeTradeDirection == "BUY" ? label.style_label_up : label.style_label_down, color = color.new(color.aqua, 0), textcolor = color.black, size = size.small)

    line.set_x2(activeEntryLine, bar_index + 20)
    line.set_x2(activeTargetLine, bar_index + 20)
    line.set_x2(activeStopLine, bar_index + 20)

plotshape(latestSignal == "BUY" and latestSizingAccepted, title = "Bot BUY Entry", style = shape.triangleup, location = location.belowbar, color = color.lime, size = size.small, text = "BUY")
plotshape(latestSignal == "SELL" and latestSizingAccepted, title = "Bot SELL Entry", style = shape.triangledown, location = location.abovebar, color = color.red, size = size.small, text = "SELL")
bgcolor(showEntryHighlight and latestSizingAccepted and latestSignal != "NONE" ? color.new(latestSignal == "BUY" ? color.lime : color.red, 92) : na)

if showLabels and latestSignal != "NONE" and barstate.isconfirmed and latestSizingAccepted
    labelStyle = latestSignal == "BUY" ? label.style_label_up : label.style_label_down
    labelY = latestSignal == "BUY" ? low : high
    labelColor = latestSignal == "BUY" ? color.lime : color.red
    string entryText = latestSignal + "\n" + str.tostring(latestTargetReachProbability, "#") + "%\nRR " + str.tostring(latestRiskRewardRatio, "#.##") + "\n+$" + str.tostring(latestExpectedProfitUsd, "#.##") + " / -$" + str.tostring(latestExpectedLossUsd, "#.##")
    label.new(bar_index, labelY, entryText, style = labelStyle, color = labelColor, textcolor = color.white, size = size.small)

if showScoreBreakdown and uiDebug and showLabels and latestSignal != "NONE" and barstate.isconfirmed
    string breakdown = "Score Breakdown\nDisplacement " + str.tostring(latestDisplacementScore, "#.##") + "\nReaction Tier " + str.tostring(latestReactionTierScore, "#.##") + "\nRR Fit " + str.tostring(latestRrFitScore, "#.##") + "\nTarget Penalty -" + str.tostring(latestTargetDistancePenalty, "#.##") + "\nFreshness " + str.tostring(latestZoneFreshnessScore, "#.##") + "\nProbability " + str.tostring(latestTargetReachProbability, "#.##")
    label.new(bar_index, latestSignal == "BUY" ? high : low, breakdown + "\n\nCandidate Ranking\n" + latestRankingText + "\n\nReason selected:\n" + latestSelectionReason, style = latestSignal == "BUY" ? label.style_label_down : label.style_label_up, color = color.new(color.black, 0), textcolor = color.white, size = size.small)

var table analysisTable = table.new(position.top_right, 2, 11, border_width = 1)
if showTable and barstate.islast
    table.cell(analysisTable, 0, 0, "Nado ICT Analysis", text_color = color.white, bgcolor = color.black)
    table.cell(analysisTable, 1, 0, syminfo.ticker, text_color = color.white, bgcolor = color.black)
    table.cell(analysisTable, 0, 1, "Signal")
    table.cell(analysisTable, 1, 1, latestSignal)
    table.cell(analysisTable, 0, 2, "Probability")
    table.cell(analysisTable, 1, 2, na(latestTargetReachProbability) ? "--" : str.tostring(latestTargetReachProbability, "#.##") + "%")
    table.cell(analysisTable, 0, 3, "Reaction")
    table.cell(analysisTable, 1, 3, latestReactionTier)
    table.cell(analysisTable, 0, 4, "Target Mode")
    table.cell(analysisTable, 1, 4, latestTargetMode)
    table.cell(analysisTable, 0, 5, "Entry")
    table.cell(analysisTable, 1, 5, activeTrade ? str.tostring(activeEntry, format.mintick) : "--")
    table.cell(analysisTable, 0, 6, "TP")
    table.cell(analysisTable, 1, 6, activeTrade ? str.tostring(activeTarget, format.mintick) : not na(latestSelectedTarget) ? str.tostring(latestSelectedTarget, format.mintick) : "--")
    table.cell(analysisTable, 0, 7, "SL")
    table.cell(analysisTable, 1, 7, activeTrade ? (activeStopAtBe ? "BE " + str.tostring(activeEntry, format.mintick) : str.tostring(activeInitialStop, format.mintick)) : not na(latestHardStopPrice) ? str.tostring(latestHardStopPrice, format.mintick) : "--")
    table.cell(analysisTable, 0, 8, "Expected P/L")
    table.cell(analysisTable, 1, 8, not na(latestExpectedProfitUsd) ? "+$" + str.tostring(latestExpectedProfitUsd, "#.##") + " / -$" + str.tostring(latestExpectedLossUsd, "#.##") : "--")
    table.cell(analysisTable, 0, 9, "RR")
    table.cell(analysisTable, 1, 9, not na(latestRiskRewardRatio) ? str.tostring(latestRiskRewardRatio, "#.##") : "--")
    table.cell(analysisTable, 0, 10, "Position Size")
    table.cell(analysisTable, 1, 10, not na(latestPositionSizeUsd) ? "$" + str.tostring(latestPositionSizeUsd, "#.##") : "--")
