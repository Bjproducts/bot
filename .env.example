# ====================================================================
# NADO TRADING BOT — SIMULATION CONFIG
# Copy this file to .env  (cp .env.example .env)
# ====================================================================

# BOT_MODE options:
# simulation  - existing simulated market/paper behavior
# paper_live  - live/read-only market data with paper trades only
# live        - real orders only if all safety gates pass
BOT_MODE=simulation

# Live execution safety defaults. Keep disabled unless intentionally testing
# the live execution layer with a supported adapter and real credentials.
LIVE_TRADING_ENABLED=false
EXCHANGE_NAME=
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=
LIVE_SYMBOL=
LIVE_ORDER_SIZE_USD=10
MAX_LIVE_ORDER_SIZE_USD=10
MAX_DAILY_LOSS_USD=5
MAX_DAILY_TRADES=5
ALLOW_SHORTS=false
REQUIRE_MANUAL_ARM=true
LIVE_ARM_CONFIRM=

# ─── Market data source ───────────────────────────────────────────────
# SIMULATOR   — synthetic GBM price feed (default, works offline)
# REAL_PUBLIC — live Binance 1-minute candles via public REST API
#               No API key required. Supported symbols: BTC ETH SOL BNB XRP ADA
# NASDAQ_PUBLIC - live public/read-only NASDAQ-style candles.
#                 Supported symbols: QQQ NDX NQ if the provider returns data.
MARKET_DATA_SOURCE=NASDAQ_PUBLIC

# REAL_PUBLIC host. Defaults to https://api.binance.com.
# Use https://data-api.binance.vision (Binance's read-only market-data
# mirror) if api.binance.com is blocked in the deployment region
# (e.g. AWS Lightsail us-east-2 returns HTTP 451 from api.binance.com).
# Schema, symbol mapping, parsing, and trading logic are unchanged.
REAL_PUBLIC_HOST=https://api.binance.com
STARTUP_CANDLE_LIMIT=500

# ─── What to trade ───────────────────────────────────────────────────
SYMBOL=QQQ
TRADE_SIDE=LONG

# Use this exact TradingView chart symbol with the Pine overlay.
# Leave blank to let the bot derive it from MARKET_DATA_SOURCE + SYMBOL.
# Examples: NASDAQ:QQQ, TVC:NDX, CME_MINI:NQ1!, BINANCE:BTCUSDT
TRADINGVIEW_SYMBOL=NASDAQ:QQQ

# ─── Risk controls ───────────────────────────────────────────────────
ORDER_SIZE_USD=100
MAX_CAP_USD=500
TAKE_PROFIT_PCT=0.006
DCA_TRIGGER_PCT=0.015
PROFIT_TARGET_USD_MIN=0.50
PROFIT_TARGET_USD_MAX=1.00
MAX_POSITION_MINUTES=5
MAX_LOSS_USD=1.00
ALLOW_MULTIPLE_POSITIONS=true
MAX_CONCURRENT_POSITIONS=3
POSITION_SIZING_MODE=RISK_FIRST
TARGET_PROFIT_MIN_USD=1.00
TARGET_PROFIT_MAX_USD=1.50
MAX_RISK_PER_TRADE_USD=0.50
STOP_MODEL=TIGHT_FVG
MIN_POSITION_USD=25
MAX_POSITION_USD=500
HARD_STOP_ENABLED=true
BREAKEVEN_TRIGGER_PROFIT_USD=0.80
PARTIAL_CLOSE_ENABLED=true
PARTIAL_CLOSE_TRIGGER_PROFIT_USD=1.30
PARTIAL_CLOSE_LOCK_PROFIT_USD=1.00

# ─── Exit target mode (Phase 5g) ─────────────────────────────────────
# STRUCTURE — target opposing FVG/IFVG; fallback to swing high/low.
# SCALP     — target = entry +/- (riskDistance * TARGET_R_MULTIPLE).
# HYBRID    — choose the closer of structure and scalp targets that
#             still satisfies MIN_RISK_REWARD_RATIO (and
#             MAX_TARGET_DISTANCE_PERCENT when > 0).
EXIT_TARGET_MODE=HYBRID
TARGET_R_MULTIPLE=1.5
MIN_RISK_REWARD_RATIO=1.5
# Reject structure targets farther than X% from entry; 0 = disabled.
MAX_TARGET_DISTANCE_PERCENT=0

# Signal source: VOLUME_SPIKE keeps the existing default behavior.
# ICT runs FVG/IFVG detection, reaction evaluation, then ICT signal conversion.
# NONE disables new signal-based paper entries.
SIGNAL_SOURCE=ICT
DEBUG_ICT_PIPELINE=true
ICT_MIN_CONFIDENCE=75
ICT_TRADE_ON_IFVG_FORMATION=true
ICT_TARGET_SWING_LEFT=3
ICT_TARGET_SWING_RIGHT=3
ICT_TARGET_FALLBACK_LOOKBACK=50

# ─── Volume Spike Reversal signal ────────────────────────────────────
VOLUME_LOOKBACK=20
VOLUME_SPIKE_MULTIPLIER=2
REVERSAL_DROP_PERCENT=1

# ─── Price simulator (used when MARKET_DATA_SOURCE=SIMULATOR) ────────
# Also sets the fallback starting price for REAL_PUBLIC
START_PRICE=65000
TICK_INTERVAL_MS=2000
PRICE_VOLATILITY=0.80
PRICE_DRIFT=0.0
BASE_VOLUME=800

# ─── REAL_PUBLIC tip ─────────────────────────────────────────────────
# With real data, candles arrive once per minute.
# Set TICK_INTERVAL_MS=60000 to match, or keep 2000 to check TP/DCA more often.
# Signal buffer needs ~20 candles (~20 min) before first trade can fire.

# ─── Session ─────────────────────────────────────────────────────────
STARTING_CAPITAL=10000
